import React, { useState } from 'react';
import { useEvents } from '../context/EventContext';
import { useNavigate } from 'react-router-dom';
import { Plus, Trash, Edit, Save, X, LogOut, Download } from 'lucide-react';
import * as XLSX from 'xlsx';
import { saveAs } from 'file-saver';

const AdminDashboard = () => {
    const { isAdmin, logout, upcomingEvents, addUpcomingEvent, updateUpcomingEvent, deleteUpcomingEvent, participants, deleteParticipant } = useEvents();
    const navigate = useNavigate();
    const [isEditing, setIsEditing] = useState(null); // ID of event being edited
    const [showAddModal, setShowAddModal] = useState(false);
    
    // Form States
    const [formData, setFormData] = useState({
        title: '',
        date: '',
        location: '',
        description: '',
        image: '',
        registrationLink: ''
    });

    if (!isAdmin) {
        navigate('/admin');
        return null;
    }

    const handleLogout = () => {
        logout();
        navigate('/admin');
    };

    const handleAddSubmit = (e) => {
        e.preventDefault();
        addUpcomingEvent({
            ...formData,
            // Simple logic for dateTarget if needed, or just ignore for now
            dateTarget: new Date(formData.date).toISOString() 
        });
        setShowAddModal(false);
        setFormData({ title: '', date: '', location: '', description: '', image: '', registrationLink: '' });
    };

    const startEdit = (event) => {
        setIsEditing(event.id);
        setFormData(event);
    };

    const cancelEdit = () => {
        setIsEditing(null);
        setFormData({ title: '', date: '', location: '', description: '', image: '', registrationLink: '' });
    };

    const saveEdit = (id) => {
        updateUpcomingEvent(id, formData);
        setIsEditing(null);
        setFormData({ title: '', date: '', location: '', description: '', image: '', registrationLink: '' });
    };

    const downloadParticipants = () => {
        if (!participants || participants.length === 0) {
            alert("No participants to download.");
            return;
        }

        // Prepare data for Excel
        const dataToExport = participants.map(p => ({
            "Full Name": p.name,
            "Registration Number": p.registrationNumber,
            "Email": p.email,
            "Phone": p.phone,
            "Event": p.event,
            "Department": p.department,
            "Year": p.year,
            "Team Name": p.teamName || "N/A",
            "Team Size": p.teamSize,
            "Team Members": p.members || "N/A",
            "Registered At": new Date(p.registeredAt).toLocaleString()
        }));

        const worksheet = XLSX.utils.json_to_sheet(dataToExport);
        const workbook = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(workbook, worksheet, "Participants");
        
        // Writes the workbook to a binary string
        const excelBuffer = XLSX.write(workbook, { bookType: 'xlsx', type: 'array' });
        
        // Create Blob
        const data = new Blob([excelBuffer], {type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;charset=UTF-8'});
        
        saveAs(data, `participants_export_${new Date().toISOString().split('T')[0]}.xlsx`);
    };

    return (
        <div className="min-h-screen bg-slate-50 dark:bg-dark-bg text-slate-900 dark:text-white p-6 md:p-12 transition-colors duration-300">
            <div className="flex justify-between items-center mb-12">
                <h1 className="text-3xl font-bold font-display">Admin Dashboard</h1>
                <button onClick={handleLogout} className="flex items-center gap-2 text-slate-600 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">
                    <LogOut size={20} /> Logout
                </button>
            </div>

            {/* Upcoming Events Management */}
            <div className="mb-12">
                <div className="flex justify-between items-center mb-6">
                    <h2 className="text-2xl font-bold">Manage Upcoming Events</h2>
                    <button 
                        onClick={() => setShowAddModal(true)}
                        className="flex items-center gap-2 px-4 py-2 bg-royal-blue rounded-lg hover:bg-royal-blue/80 transition-colors text-white"
                    >
                        <Plus size={18} /> Add Event
                    </button>
                </div>

                <div className="grid gap-6">
                    {upcomingEvents.map(event => (
                        <div key={event.id} className="bg-white dark:bg-[#1e293b] p-6 rounded-xl border border-slate-200 dark:border-white/10 flex flex-col md:flex-row gap-6 shadow-sm dark:shadow-none transition-colors">
                           {/* Image Preview */}
                           <div className="w-full md:w-48 h-32 bg-slate-100 dark:bg-dark-bg rounded-lg overflow-hidden shrink-0">
                                {event.image ? (
                                    <img src={event.image} alt={event.title} className="w-full h-full object-cover" />
                                ) : (
                                    <div className="w-full h-full flex items-center justify-center text-slate-400 dark:text-gray-500 text-xs">No Image</div>
                                )}
                           </div>

                           {/* Content or Edit Form */}
                           <div className="flex-1">
                                {isEditing === event.id ? (
                                    <div className="grid gap-4">
                                        <input className="bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 text-slate-900 dark:text-white p-2 rounded" value={formData.title} onChange={e => setFormData({...formData, title: e.target.value})} placeholder="Title" />
                                        <div className="grid grid-cols-2 gap-4">
                                            <input className="bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 text-slate-900 dark:text-white p-2 rounded" value={formData.date} onChange={e => setFormData({...formData, date: e.target.value})} placeholder="Date string (e.g. March 15, 2026)" />
                                            <input className="bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 text-slate-900 dark:text-white p-2 rounded" value={formData.location} onChange={e => setFormData({...formData, location: e.target.value})} placeholder="Location" />
                                        </div>
                                        <textarea className="bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 text-slate-900 dark:text-white p-2 rounded" rows="2" value={formData.description} onChange={e => setFormData({...formData, description: e.target.value})} placeholder="Description" />
                                        <input className="bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 text-slate-900 dark:text-white p-2 rounded" value={formData.registrationLink} onChange={e => setFormData({...formData, registrationLink: e.target.value})} placeholder="Registration Link (e.g. https://forms.google.com/...)" />
                                        <input className="bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 text-slate-900 dark:text-white p-2 rounded" value={formData.image} onChange={e => setFormData({...formData, image: e.target.value})} placeholder="Image URL" />
                                        
                                        <div className="flex gap-2 mt-2">
                                            <button onClick={() => saveEdit(event.id)} className="px-3 py-1 bg-green-600 rounded flex items-center gap-1 text-sm text-white"><Save size={14}/> Save</button>
                                            <button onClick={cancelEdit} className="px-3 py-1 bg-gray-600 rounded flex items-center gap-1 text-sm text-white"><X size={14}/> Cancel</button>
                                        </div>
                                    </div>
                                ) : (
                                    <>
                                        <div className="flex justify-between items-start">
                                            <h3 className="text-xl font-bold mb-2 text-slate-900 dark:text-white">{event.title}</h3>
                                            <div className="flex gap-2">
                                                <button onClick={() => startEdit(event)} className="p-2 bg-blue-500/10 text-blue-500 dark:text-blue-400 rounded hover:bg-blue-500/20"><Edit size={16} /></button>
                                                <button onClick={() => deleteUpcomingEvent(event.id)} className="p-2 bg-red-500/10 text-red-500 dark:text-red-400 rounded hover:bg-red-500/20"><Trash size={16} /></button>
                                            </div>
                                        </div>
                                        <p className="text-slate-600 dark:text-gray-400 text-sm mb-4">{event.description}</p>
                                        <div className="flex flex-wrap gap-4 text-sm text-slate-500 dark:text-gray-500">
                                            <span>📅 {event.date}</span>
                                            <span>📍 {event.location}</span>
                                            <span className="text-electric-purple text-xs border border-electric-purple/30 px-2 py-0.5 rounded">
                                                Link: {event.registrationLink || 'Default'}
                                            </span>
                                        </div>
                                    </>
                                )}
                           </div>
                        </div>
                    ))}
                </div>
            </div>

            {/* Add Modal */}
            {showAddModal && (
                <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 dark:bg-black/80 backdrop-blur-sm">
                    <div className="bg-white dark:bg-[#1e293b] p-8 rounded-2xl w-full max-w-lg border border-slate-200 dark:border-white/10 shadow-2xl">
                        <h3 className="text-2xl font-bold mb-6 text-slate-900 dark:text-white">Add New Event</h3>
                        <form onSubmit={handleAddSubmit} className="space-y-4">
                            <input className="w-full bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 p-3 rounded-lg text-slate-900 dark:text-white" value={formData.title} onChange={e => setFormData({...formData, title: e.target.value})} placeholder="Event Title" required />
                            <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <input className="w-full bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 p-3 rounded-lg text-slate-900 dark:text-white" value={formData.date} onChange={e => setFormData({...formData, date: e.target.value})} placeholder="Date (e.g. Dec 31)" required />
                                <input className="w-full bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 p-3 rounded-lg text-slate-900 dark:text-white" value={formData.location} onChange={e => setFormData({...formData, location: e.target.value})} placeholder="Location" required />
                            </div>
                            <textarea className="w-full bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 p-3 rounded-lg text-slate-900 dark:text-white" rows="3" value={formData.description} onChange={e => setFormData({...formData, description: e.target.value})} placeholder="Event Description" required />
                            <input className="w-full bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 p-3 rounded-lg text-slate-900 dark:text-white" value={formData.registrationLink} onChange={e => setFormData({...formData, registrationLink: e.target.value})} placeholder="Registration/Google Form Link" />
                            <input className="w-full bg-slate-50 dark:bg-dark-bg border border-slate-300 dark:border-white/10 p-3 rounded-lg text-slate-900 dark:text-white" value={formData.image} onChange={e => setFormData({...formData, image: e.target.value})} placeholder="Image URL (Optional)" />
                            
                            <div className="flex gap-4 pt-4">
                                <button type="submit" className="flex-1 py-3 bg-electric-purple rounded-lg font-bold hover:bg-electric-purple/90 text-white">Add Event</button>
                                <button type="button" onClick={() => setShowAddModal(false)} className="flex-1 py-3 bg-slate-200 dark:bg-white/5 rounded-lg font-bold hover:bg-slate-300 dark:hover:bg-white/10 text-slate-900 dark:text-white">Cancel</button>
                            </div>
                        </form>
                    </div>
                </div>
            )}

            {/* Participants Table */}
            <div className="mt-12">
                <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
                    <h2 className="text-2xl font-bold">Registered Participants</h2>
                    <div className="flex gap-3 w-full md:w-auto">
                         <button 
                            onClick={() => window.location.reload()}
                            className="flex-1 md:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors text-white"
                        >
                            Refresh
                        </button>
                        <button 
                            onClick={downloadParticipants}
                            className="flex-1 md:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-green-600 rounded-lg hover:bg-green-700 transition-colors text-white"
                        >
                            <Download size={18} /> Export
                        </button>
                    </div>
                </div>

                {/* Desktop View */}
                <div className="hidden md:block bg-white dark:bg-[#1e293b] rounded-xl border border-slate-200 dark:border-white/10 overflow-hidden shadow-sm dark:shadow-none">
                    <div className="overflow-x-auto">
                        <table className="w-full text-left">
                            <thead className="bg-slate-100 dark:bg-white/5">
                                <tr>
                                    <th className="p-4 font-semibold text-slate-700 dark:text-gray-300">Name</th>
                                    <th className="p-4 font-semibold text-slate-700 dark:text-gray-300">Reg No</th>
                                    <th className="p-4 font-semibold text-slate-700 dark:text-gray-300">Contact</th>
                                    <th className="p-4 font-semibold text-slate-700 dark:text-gray-300">Event</th>
                                    <th className="p-4 font-semibold text-slate-700 dark:text-gray-300">Dept/Year</th>
                                    <th className="p-4 font-semibold text-slate-700 dark:text-gray-300">Status</th>
                                    <th className="p-4 font-semibold text-slate-700 dark:text-gray-300">Actions</th>
                                </tr>
                            </thead>
                            <tbody className="divide-y divide-slate-200 dark:divide-white/10">
                                {participants && participants.length > 0 ? (
                                    participants.map((p) => (
                                        <tr key={p.id} className="hover:bg-slate-50 dark:hover:bg-white/5 transition-colors">
                                            <td className="p-4 font-medium text-slate-900 dark:text-white">
                                                {p.name}
                                                {p.teamName && <div className="text-xs text-slate-500 dark:text-gray-500 font-bold mt-1">Team: {p.teamName}</div>}
                                                {p.members && <div className="text-xs text-slate-500 dark:text-gray-500 italic mt-0.5">Members: {p.members}</div>}
                                            </td>
                                            <td className="p-4 text-electric-purple font-mono text-sm">{p.registrationNumber}</td>
                                            <td className="p-4 text-slate-600 dark:text-gray-400">
                                                <div className="text-sm">{p.phone}</div>
                                                <div className="text-xs opacity-75">{p.email}</div>
                                            </td>
                                            <td className="p-4 text-electric-purple">{p.event}</td>
                                            <td className="p-4 text-slate-600 dark:text-gray-400 text-sm">{p.department} - {p.year}</td>
                                            <td className="p-4">
                                                <div className="flex flex-col gap-1">
                                                    <span className="text-xs text-slate-500 dark:text-gray-500">
                                                        {new Date(p.registeredAt).toLocaleDateString()}
                                                    </span>
                                                    {p.whatsappStatus && (
                                                        <span className={`text-xs px-2 py-0.5 rounded-full border w-fit ${
                                                            p.whatsappStatus === 'joined' 
                                                            ? 'bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-400 dark:border-green-800' 
                                                            : 'bg-amber-100 text-amber-700 border-amber-200 dark:bg-amber-900/30 dark:text-amber-400 dark:border-amber-800'
                                                        }`}>
                                                            WH: {p.whatsappStatus}
                                                        </span>
                                                    )}
                                                </div>
                                            </td>
                                            <td className="p-4">
                                                <button 
                                                    onClick={() => {
                                                        if(window.confirm('Are you sure you want to delete this participant?')) {
                                                            deleteParticipant(p.id);
                                                        }
                                                    }}
                                                    className="p-2 bg-red-500/10 text-red-500 dark:text-red-400 rounded hover:bg-red-500/20 transition-colors"
                                                    title="Delete Participant"
                                                >
                                                    <Trash size={16} />
                                                </button>
                                            </td>
                                        </tr>
                                    ))
                                ) : (
                                    <tr>
                                        <td colSpan="8" className="p-8 text-center text-slate-500 dark:text-gray-500">
                                            No partcipants registered yet.
                                        </td>
                                    </tr>
                                )}
                            </tbody>
                        </table>
                    </div>
                </div>

                {/* Mobile Card View */}
                <div className="md:hidden space-y-4">
                    {participants && participants.length > 0 ? (
                        participants.map((p) => (
                            <div key={p.id} className="bg-white dark:bg-[#1e293b] p-4 rounded-xl border border-slate-200 dark:border-white/10 shadow-sm space-y-3 relative">
                                <button 
                                    onClick={() => {
                                        if(window.confirm('Are you sure you want to delete this participant?')) {
                                            deleteParticipant(p.id);
                                        }
                                    }}
                                    className="absolute top-4 right-4 p-2 bg-red-500/10 text-red-500 dark:text-red-400 rounded hover:bg-red-500/20 transition-colors"
                                    title="Delete Participant"
                                >
                                    <Trash size={16} />
                                </button>

                                <div>
                                    <h3 className="font-bold text-slate-900 dark:text-white text-lg">{p.name}</h3>
                                    <div className="text-electric-purple font-mono text-sm">{p.registrationNumber}</div>
                                </div>
                                
                                {p.teamName && (
                                    <div className="bg-slate-50 dark:bg-white/5 p-2 rounded">
                                        <div className="text-xs text-slate-500 dark:text-gray-500 font-bold">Team: <span className="text-slate-700 dark:text-slate-300">{p.teamName}</span></div>
                                        {p.members && <div className="text-xs text-slate-500 dark:text-gray-500 italic mt-1">{p.members}</div>}
                                    </div>
                                )}

                                <div className="grid grid-cols-2 gap-2 text-sm">
                                    <div>
                                        <span className="text-xs text-slate-500 dark:text-gray-500 block">Event</span>
                                        <span className="text-slate-700 dark:text-gray-300">{p.event}</span>
                                    </div>
                                    <div>
                                        <span className="text-xs text-slate-500 dark:text-gray-500 block">Contact</span>
                                        <span className="text-slate-700 dark:text-gray-300">{p.phone}</span>
                                    </div>
                                </div>

                                <div className="flex justify-between items-center pt-2 border-t border-slate-100 dark:border-white/5">
                                    <div className="text-xs text-slate-500 dark:text-gray-500">
                                        {new Date(p.registeredAt).toLocaleDateString()}
                                    </div>
                                    {p.whatsappStatus && (
                                        <span className={`text-xs px-2 py-0.5 rounded-full border ${
                                            p.whatsappStatus === 'joined' 
                                            ? 'bg-green-100 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-400 dark:border-green-800' 
                                            : 'bg-amber-100 text-amber-700 border-amber-200 dark:bg-amber-900/30 dark:text-amber-400 dark:border-amber-800'
                                        }`}>
                                            WH: {p.whatsappStatus}
                                        </span>
                                    )}
                                </div>
                            </div>
                        ))
                    ) : (
                         <div className="bg-white dark:bg-[#1e293b] p-8 rounded-xl border border-slate-200 dark:border-white/10 text-center text-slate-500 dark:text-gray-500">
                            No participants registered yet.
                        </div>
                    )}
                </div>
            </div>
        </div>
    );
};

export default AdminDashboard;
